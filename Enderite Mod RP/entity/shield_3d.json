{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "multimc:shield_item",
			"materials": {
				"default": "entity_emissive_alpha"
			},
			"textures": {
				"enderite_shield": "textures/entity/enderite_shield/enderite_shield"
			},
			"geometry": {
				"enderite_shield": "geometry.enderite_shield"
			},
			"animations": {
				"move": "animation.shield_item.rotate"
			},
			"scripts": {
				"pre_animation": [
					"variable.shake = query.shake_time - query.frame_alpha;",
					"variable.shake_power = variable.shake > 0.0 ? -Math.sin(variable.shake * 200.0) * variable.shake : 0.0;"
				],
				"animate": [
					"move"
				]
			},
			"render_controllers": [
				"controller.render.shield_entity_3d"
			]
		}
	}
}