{
	"format_version": "1.8.0",
	"render_controllers": {
		"controller.render.enderite_shield": {
			"uv_anim": {
				"offset": [
					0,
					"math.mod(math.floor(query.life_time),2)/2"
				],
				"scale": [
					1,
					"0.5"
				]
			},
			"geometry": "geometry.enderite_shield",
			"materials": [
				{
					"*": "variable.is_enchanted?material.enchanted:material.default"
				}
			],
			"textures": [
				"texture.enderite_shield",
				"texture.enchanted"
			]
		}
	}
}