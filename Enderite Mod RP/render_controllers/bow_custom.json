					]
				},
				"geometries": {
					"array.bow_geo_frames": [
						"geometry.default",
						"geometry.crossbow_pulling_0",
						"geometry.crossbow_pulling_1",
						"geometry.crossbow_pulling_2",
						"geometry.crossbow_arrow"
					]
				}
			},
			"geometry": "array.bow_geo_frames[variable.charge_amount]",
			"materials": [
				{
					"*": "variable.is_enchanted?material.enchanted:material.default"
				}
			],
			"textures": [
				"array.bow_texture_frames[variable.charge_amount]",
				"texture.enchanted"
			]
		}
	}
