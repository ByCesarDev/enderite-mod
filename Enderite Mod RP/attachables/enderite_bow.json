{
	"format_version": "1.10.0",
	"minecraft:attachable": {
		"description": {
			"identifier": "ed:enderite_bow",
			"materials": {
				"default": "entity_alphatest",
				"enchanted": "entity_alphatest_glint"
			},
			"textures": {
				"default": "textures/items/enderite_bow",
				"bow_pulling_0": "textures/items/enderite_bow_pulling_0",
				"bow_pulling_1": "textures/items/enderite_bow_pulling_1",
				"bow_pulling_2": "textures/items/enderite_bow_pulling_2",
				"enchanted": "textures/misc/enchanted_item_glint"
			},
			"geometry": {
				"default": "geometry.bow_standby",
				"bow_pulling_0": "geometry.bow_pulling_0",
				"bow_pulling_1": "geometry.bow_pulling_1",
				"bow_pulling_2": "geometry.bow_pulling_2"
			},
			"animations": {
				"wield": "animation.player.bow_custom.first_person",
				"thierd": "animation.player.bow_custom",
				"wield_first_person_pull": "animation.custom_bow.wield_first_person_pull"
			},
			"scripts": {
				"pre_animation": [
					"variable.charge_time = query.is_using_item ? variable.charge_time + 1 : 0;",
					"variable.charge_amount = (variable.charge_time >= 60) ? 3 : (variable.charge_time >= 40 ? 2 : (variable.charge_time >= 20 ? 1 : 0));"
				],
				"animate": [
					{
						"wield": "c.is_first_person"
					},
					{
						"thierd": "!c.is_first_person"
					},
					{
						"wield_first_person_pull": "query.is_using_item && c.is_first_person && (temp.value = 0; temp.index = 0; loop(27, {temp.value = (query.is_item_name_any('slot.inventory', temp.index, 'ed:enderite_arrow') || (query.is_item_name_any('slot.hotbar', temp.index, 'ed:enderite_arrow'))); temp.value ? {return temp.value;}; temp.index = temp.index+1;}););"
					}
				]
			},
			"render_controllers": [
				"controller.render.bow_custom"
			]
		}
	}
}